# ====================================================================
# Spring Boot 환경변수 예시
# 운영 시 실제 값을 채워서 사용 (절대 git에 커밋 X)
# ====================================================================

# --- DB (Supabase Transaction Pooler) ---
# 핵심: channelBinding=disable (SCRAM 인증 호환), prepareThreshold=0 (pooler 호환)
DB_URL=jdbc:postgresql://aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require&channelBinding=disable&prepareThreshold=0
DB_USERNAME=postgres.your_project_ref
DB_PASSWORD=your_db_password

# --- 프로필 ---
# 로컬: local (기본값) / 운영: prod
SPRING_PROFILES_ACTIVE=local

# --- 서버 포트 ---
SERVER_PORT=8080

# --- CORS 허용 origin (쉼표 구분) ---
# 로컬: http://localhost:3000
# 운영 예시: https://your-app.vercel.app,https://your-domain.com
CORS_ORIGINS=http://localhost:3000

# --- OpenAI (WordSim 동적 임베딩용, 선택사항) ---
# 비어있으면 사전(word_vectors.bin)에 등록된 단어만 처리 가능
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=
